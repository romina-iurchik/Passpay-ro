generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql" //  sqlite

  // Runtime (serverless/Vercel) usa el transaction pooler (6543, pgbouncer).
  // Las migraciones usan la conexión de sesión (5432) via directUrl.
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Split {
  id              String    @id @default(uuid())
  totalAmount     Float
  mode            String
  status          String    @default("PENDING")
  network         String
  assetType       String
  assetCode       String
  assetIssuer     String?
  webhookUrl      String?
  stellarTxHash   String?
  createdAt       DateTime  @default(now())
  expiresAt       DateTime?
  releasedAt      DateTime?
  payments        Payment[]
}

model Payment {
  id              String   @id @default(uuid())
  splitId         String
  split           Split    @relation(fields: [splitId], references: [id])
  payerId         String
  method          String
  originalAsset   String
  originalAmount  Float
  conversionRate  Float    @default(1)
  convertedAmount Float
  externalStatus  String   @default("CONFIRMED")
  createdAt       DateTime @default(now())
}

model T3Transaction {
  id                  String   @id @default(uuid())
  amountArs           Float
  reference           String
  status              String   @default("ACCREDITED")
  bankTransactionId   String?
  coelsaId            String?
  stellarTxHash       String?
  settlementAsset     String?
  settlementAmount    String?
  payer               String?
  createdAt           DateTime @default(now())
}

model AnchorTransaction {
  id                    String   @id @default(uuid())
  direction             String   // deposit | withdraw
  amount                String?
  anchorTransactionId   String?
  interactiveUrl        String?
  status                String   @default("pending")
  assetCode             String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

model BlindPayPayout {
  id              String   @id @default(uuid())
  payoutId        String?
  quoteId         String?
  receiverId      String?
  bankAccountId   String?
  requestAmount   Int?
  receiverAmount  Int?
  status          String   @default("pending")
  stellarTxHash   String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}