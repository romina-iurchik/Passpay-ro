# Database
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Passpay
PASSPAY_SECRET=                 # Clave secreta de la app (firma settlements)
# PASSPAY_SETTLEMENT_SOURCE=native   # "native" o ASSET_CODE:ISSUER (ej. USDC:GBBD...)

# Stellar - Cuentas
MERCHANT_PUBLIC=                # Clave pública del comercio
MERCHANT_SECRET=                # Clave privada del comercio
ISSUER_PUBLIC=                  # Clave pública de Passpay (source_account para Horizon)
ISSUER_SECRET=                  # Clave privada de Passpay

# Stellar - Red
STELLAR_NETWORK=testnet                                       # testnet | mainnet
STELLAR_HORIZON_URL_TESTNET=https://horizon-testnet.stellar.org
STELLAR_HORIZON_URL_MAINNET=https://horizon.stellar.org

# Anchor (on/off-ramp dólar ↔ ARS) — SEP-1 / SEP-10 / SEP-24
ANCHOR_PROVIDER=reference       # reference (testanchor.stellar.org) | anclap
# ANCHOR_HOME_DOMAIN=           # override del dominio del anchor (opcional)
# ANCHOR_ASSET_CODE=USDC        # asset on-chain del ramp (override opcional)
# ANCHOR_FIAT_CURRENCY=USD      # moneda fiat informativa (override opcional)
# RAMP_SECRET=                  # secret de la cuenta de tesorería que firma SEP-10 (default: PASSPAY_SECRET)
# --- Anclap (Argentina, ARS ↔ USDC) ---
# ANCLAP_HOME_DOMAIN=           # dominio del sandbox/anchor de Anclap (pedir credenciales)
# ANCLAP_ASSET_CODE=ARS

# Transferencias 3.0 (BCRA) — rail de cobro en ARS
PASSPAY_CVU=0000003100099999999999   # CVU recaudador (22 dígitos)
PASSPAY_ALIAS=passpay.ars
PASSPAY_MERCHANT_NAME=PASSPAY
PASSPAY_MERCHANT_CITY=BUENOS AIRES
T3_ARS_PER_USD=1477             # fallback ARS→USD; el valor real lo trae el BCRA (rate.service.ts)
T3_SETTLE_ASSET_CODE=XLM        # asset de liquidación on-chain (XLM | USDC)
# T3_SETTLE_ASSET_ISSUER=       # issuer si T3_SETTLE_ASSET_CODE es de crédito
T3_USD_PER_XLM=0.1              # referencia USD→XLM para settlement nativo

# Assets
ISSUER_PUBLIC_ASSET=            # Issuer de USDC
                                # Circle testnet: GBBD47IF6LWK7P7MDEVSCWR7DPUWV3NY3DTQEVFL4NAT4AQH3ZLLFLA5
                                # Circle mainnet: GA5ZSEJYB37JRC5AVCIA5MOP4RHTM335X2KGX3IHOJAPP5RE34K4KZVN

# BlindPay (off-ramp USDC → ARS/BRL/COP via rails locales — CVU / PIX / PSE)
# Solicitar credenciales en https://blindpay.com
BLINDPAY_BASE_URL=https://api.blindpay.com/v1
BLINDPAY_API_KEY=                          # Bearer token de BlindPay
BLINDPAY_INSTANCE_ID=                      # Instance ID del tenant en BlindPay
BLINDPAY_NETWORK=stellar_testnet           # stellar_testnet (sandbox) | stellar (prod)
BLINDPAY_TOKEN=USDB                        # USDB (sandbox) | USDC (prod)
# La moneda fiat de destino la define el rail del bank account (transfers_bitso → ARS),
# no hay un campo target_currency. request_amount va en centavos (5000 = 50.00).

# Abroad Finance (off-ramp USDC→BRL/COP) — https://api.abroad.finance/docs/
ABROAD_BASE_URL=https://api.abroad.finance
ABROAD_API_KEY=                            # solicitar credenciales sandbox a Abroad Finance

# Coelsa webhook (Transferencias 3.0 — acreditación real)
COELSA_WEBHOOK_SECRET=                     # HMAC-SHA256 secret que provee Coelsa

# MercadoPago
MP_ACCESS_TOKEN=                           # Token de MP (sandbox o producción)