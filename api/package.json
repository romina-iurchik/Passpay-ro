{
  "name": "passpay-backend",
  "version": "1.0.0",
  "main": "index.js",
  "description": "Passpay — orquestación de pagos sobre Stellar (Transferencias 3.0 + anchor SEP-24)",
  "scripts": {
    "test": "jest --runInBand",
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc",
    "vercel-build": "prisma generate && tsc",
    "postinstall": "prisma generate",
    "start": "node dist/index.js"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "jest": {
    "testEnvironment": "node",
    "testMatch": ["**/__tests__/**/*.test.ts"],
    "transform": {
      "^.+\\.tsx?$": [
        "ts-jest",
        {
          "tsconfig": {
            "types": ["node", "jest"],
            "esModuleInterop": true,
            "skipLibCheck": true
          }
        }
      ]
    }
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jest": "^29.5.14",
    "@types/node": "^25.3.2",
    "@types/qrcode": "^1.5.6",
    "@types/supertest": "^7.2.0",
    "@types/uuid": "^10.0.0",
    "jest": "^29.7.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.11",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "@stellar/stellar-sdk": "^14.5.0",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^4.22.1",
    "mercadopago": "^3.1.0",
    "prisma": "^5.22.0",
    "qrcode": "^1.5.4",
    "stellar-sdk": "^13.3.0",
    "uuid": "^13.0.0",
    "zod": "^4.3.6"
  }
}
